# ===== Bug/Issue Triage OpenEnv — Environment Variables =====
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

HF_TOKEN="your hf token here"

# API endpoint (Hugging Face Router, OpenAI-compatible)
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for baseline inference
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Docker image name
IMAGE_NAME=antigravity-bugtriage

# Task set to run: easy, medium, hard, or all
TASK_SET=easy|medium|hard
