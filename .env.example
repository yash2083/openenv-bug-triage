# ===== Bug/Issue Triage OpenEnv — Environment Variables =====
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Hugging Face token for baseline inference (OpenAI-compatible via HF Router)
HF_TOKEN=

# API endpoint (HF Router provides OpenAI-compatible API)
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for baseline inference
MODEL_NAME=Qwen/Qwen2.5-32B-Instruct

# Docker image name
IMAGE_NAME=antigravity-bugtriage

# Task set to run: easy, medium, hard, or all
TASK_SET=easy|medium|hard
